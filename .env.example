# Copy to .env and fill in secrets locally. Do not commit .env.

SPORTS_API_KEY=
SPORTS_API_FOOTBALL_KEY=
SPORTS_BASKETBALL_API_KEY=
SPORTS_TENNIS_API_KEY=
SPORTS_CRICKET_API_KEY=
FOOTBALL_DATA_TOKEN=   # optional: football-data.org free token (World Cup fixtures/tables)
# World Cup 2026 also uses keyless public sources (no token needed):
#   OpenFootball worldcup.json  — full 104-match schedule + results
#   TheStatsAPI fixtures.json    — clean UTC kick-off times + stadiums (attribution)
THESPORTSDB_KEY=       # optional: override the free public "3" test key

HF_TOKEN=
HF_DATASET_REPO=ruslanmv/sports-trends-dataset
HF_MODEL_REPO=ruslanmv/sports-trends-models

SPORTS_SITE_BASE_URL=https://ruslanmv.com/sports/
SPORTS_PRODUCT_NAME=Ruslan Magana Sports Intelligence
SPORTS_TECHNICAL_NAME=sports-trends
SPORTS_UPDATE_CYCLE_MINUTES=30
