# .env.example - Copy to .env and fill in your credentials
# DO NOT commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_URL=postgresql://admin:your_password@localhost:5432/sports_predictions
DB_USER=admin
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sports_predictions

# ============================================================================
# REDIS CACHE
# ============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# API KEYS - SPORTS DATA PROVIDERS
# ============================================================================

# RapidAPI (Required for API-Football)
# Get key at: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=api-football-v3.p.rapidapi.com

# Football-Data.org (Required)
# Get key at: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_football_data_key_here

# ESPN API (No key needed, but respectful rate limiting required)
ESPN_API_RATE_LIMIT=1  # Requests per second

# Understat (Optional - requires reverse engineering)
UNDERSTAT_EMAIL=your_understat_email@example.com
UNDERSTAT_PASSWORD=your_understat_password

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=True
SECRET_KEY=your_secret_key_for_jwt_tokens_here

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True  # Auto-reload on code changes (dev only)

# Application Settings
MAX_WORKERS=4
BATCH_SIZE=32
MODEL_CACHE_TTL=21600  # 6 hours in seconds

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================

# Model Training
TRAINING_WINDOW_SEASONS=3  # Number of seasons to use for training
VALIDATION_SPLIT=0.2
TEST_SPLIT=0.1
RANDOM_STATE=42

# Model Hyperparameters
XGBOOST_MAX_DEPTH=7
XGBOOST_LEARNING_RATE=0.1
XGBOOST_N_ESTIMATORS=500
XGBOOST_EARLY_STOPPING_ROUNDS=50

# Feature Engineering
FORM_WINDOW=5  # Matches to consider for recent form
MIN_MATCHES_FOR_PREDICTION=10  # Minimum matches played before prediction

# ============================================================================
# SCHEDULING & BACKGROUND JOBS
# ============================================================================

# Data Collection Schedule (Cron expressions)
FIXTURE_UPDATE_SCHEDULE=0 6 * * *  # Daily at 6 AM
MODEL_RETRAIN_SCHEDULE=0 2 * * 0   # Weekly on Sunday at 2 AM
STATS_CACHE_REFRESH=0 */6 * * *    # Every 6 hours

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=5

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
SENTRY_DSN=  # Optional: Sentry error tracking

# ============================================================================
# BETTING & ODDS CONFIGURATION
# ============================================================================

# Betting Platforms (for affiliate/integration)
BETFAIR_API_KEY=  # Optional
BETFAIR_APP_KEY=
BETFAIR_CERT_PATH=

# Odds API (for comparison)
ODDS_API_KEY=  # Optional: Get from https://the-odds-api.com
ODDS_UPDATE_FREQUENCY=3600  # 1 hour

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password  # Use app-specific password for Gmail
NOTIFICATION_EMAIL=recipient@example.com

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=  # For alerts
SLACK_BOT_TOKEN=

# PagerDuty (Optional)
PAGERDUTY_INTEGRATION_KEY=

# ============================================================================
# CLOUD DEPLOYMENT (Optional)
# ============================================================================

# AWS Configuration
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sports-predictions-data
AWS_SQS_QUEUE_URL=

# GCP Configuration
GCP_PROJECT_ID=
GCP_CREDENTIALS_JSON=

# Azure Configuration
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# ============================================================================
# FEATURE FLAGS & EXPERIMENTAL
# ============================================================================

# Feature Flags
ENABLE_LIVE_PREDICTIONS=True
ENABLE_INJURIES_FEATURE=True
ENABLE_SENTIMENT_ANALYSIS=False  # Requires additional setup
ENABLE_COMPUTER_VISION=False     # Requires additional models

# Experimental Models
USE_BAYESIAN_MODEL=False
USE_NEURAL_NETWORK_MODEL=False
USE_ENSEMBLE_VOTING=True

# ============================================================================
# RESPONSIBLE AI & COMPLIANCE
# ============================================================================

# Responsible Gambling
INCLUDE_GAMBLING_WARNING=True
BETTING_RISK_DISCLAIMER=True
HELP_HOTLINE=1-800-GAMBLER

# Data Privacy
GDPR_COMPLIANT=True
DATA_RETENTION_DAYS=730  # 2 years
ANONYMIZE_LOGS=True

# ============================================================================
# DEVELOPMENT/TESTING
# ============================================================================

# Test Configuration
TEST_DATABASE_URL=postgresql://admin:password@localhost:5432/sports_predictions_test
PYTEST_COVERAGE_THRESHOLD=80

# Mock Data
USE_MOCK_API_DATA=False  # For testing without real API calls
MOCK_DATA_PATH=./test_data/
